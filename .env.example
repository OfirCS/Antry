# Antry — environment variables
# Copy to .env.local and fill in real values. See SETUP.md for full setup.

# ── Supabase ─────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SERVER ONLY — bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Site ─────────────────────────────────────────────
# Used for OAuth redirects. localhost:3000 in dev; production URL otherwise.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Receipts / MCP ───────────────────────────────────
# HMAC secret used to sign Receipts. Rotate carefully —
# old Receipts verify against the secret in use at signing time.
ANTRY_RECEIPT_SECRET=

# CO2 grid intensity for compute-footprint. Defaults to 370 (US).
# Set 250 (EU) / 600 (CN) if your data centre is regional.
ANTRY_CO2_GRAMS_PER_KWH=

# ── Anthropic API ────────────────────────────────────
# Required for the Agent-as-Judge grader at submit_attempt time.
ANTHROPIC_API_KEY=sk-ant-...

# ── Discovery / Scout ────────────────────────────────
# Comma-separated Supabase user IDs allowed into /admin/discovery and the
# Scout builder-profiler. Required — without it both return Unauthorized.
ADMIN_USER_IDS=
# GitHub personal access token. No scopes needed (public data only).
# Without it the GitHub API caps at 60 req/hr; one Scout run uses ~26.
GITHUB_TOKEN=
# Shared secret for the discovery scan cron route (sent as x-cron-secret).
CRON_SECRET=

# ── Dev fixtures (NEVER set in production) ──────────
ANTRY_DEMO_FIXTURE=

# Local auth bypass for testing protected pages without OAuth/password login.
# Ignored in production by src/lib/auth-bypass.ts.
AUTH_BYPASS=false
NEXT_PUBLIC_AUTH_BYPASS=false
